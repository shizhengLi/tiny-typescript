{
  "name": "tiny-typescript-series",
  "version": "1.0.0",
  "private": true,
  "description": "Runnable TypeScript examples for a 14-part Chinese learning series.",
  "scripts": {
    "dev": "tsx src/index.ts",
    "chapter": "tsx src/index.ts",
    "list": "tsx src/index.ts list",
    "all": "tsx src/index.ts all",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js list"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
